<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:layout_weight="1"
    app:cardBackgroundColor="@color/surface_luxury"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#1AFFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvMacroLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTEIN"
            android:textColor="@color/text_muted_gold"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/tvMacroValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="0g"
            android:textColor="@color/text_off_white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/macroProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:indicatorColor="@color/gold_primary"
            app:trackColor="#1AFFFFFF"
            app:trackCornerRadius="4dp"
            app:trackThickness="6dp"
            android:progress="45" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
