<?xml version="1.0" encoding="utf-8"?>
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProfessionalName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dr. John Smith"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvServiceType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Training"
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRMED"
                android:textStyle="bold"
        </LinearLayout>

        <!-- Member Details (Initially hidden, shown for professionals) -->
        <LinearLayout
            android:id="@+id/layoutMemberInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvHealthCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Condition: None"
                android:textSize="13sp"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Date and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Jan 15, 2024"
                android:textSize="14sp"
                android:drawableStart="@drawable/baseline_calendar_month_24"

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00 AM"
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:visibility="gone" />

                android:id="@+id/btnReschedule"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Reschedule"
                android:visibility="gone" />

                android:id="@+id/btnRate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Rate"
                android:visibility="gone" />

                android:id="@+id/btnCreateReport"
                android:layout_width="0dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="Create Report"
                android:visibility="gone" />

                android:id="@+id/btnViewReport"
                android:layout_width="0dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="View Report"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
