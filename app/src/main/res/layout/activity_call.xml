<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/call_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Remote Video Status Overlay -->
    <TextView
        android:id="@+id/remote_status_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Local View with Rounded Corners -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/local_view_container"
        android:layout_width="120dp"
        android:layout_height="180dp"
        android:layout_margin="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/local_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Wait State / Connecting Overlay -->

    <!-- Header Info -->
    <LinearLayout
        android:id="@+id/connecting_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        tools:layout_editor_absoluteX="-16dp"
        tools:layout_editor_absoluteY="0dp">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"

        <TextView
            android:id="@+id/connecting_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/call_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/call_timer_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
    </LinearLayout>

    <!-- Fitness Data Overlay -->
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_live_steps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_live_heart_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    <!-- Controls Container -->
    <LinearLayout
        android:id="@+id/controls_layout"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/toggle_microphone_button"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"

        <ImageButton
            android:id="@+id/toggle_camera_button"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"

        <ImageButton
            android:id="@+id/end_call_button"
            android:background="@drawable/circle_background_red"
            android:src="@drawable/ic_end_call" />

        <ImageButton
            android:id="@+id/switch_camera_button"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"

        <ImageButton
            android:id="@+id/toggle_audio_device"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
