<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/call_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Remote Video Status Overlay -->
    <TextView
        android:id="@+id/remote_status_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User's camera is off"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Local View with Rounded Corners -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/local_view_container"
        android:layout_width="120dp"
        android:layout_height="180dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/local_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Wait State / Connecting Overlay -->

    <!-- Header Info -->
    <LinearLayout
        android:id="@+id/connecting_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        tools:layout_editor_absoluteX="-16dp"
        tools:layout_editor_absoluteY="0dp">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/accent" />

        <TextView
            android:id="@+id/connecting_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Connecting to Professional..."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/call_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call with"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/call_timer_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="00:00"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- Fitness Data Overlay -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_live_steps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Steps: --"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_live_heart_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Heart: -- bpm"
            android:textColor="#FF4444"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Controls Container -->
    <LinearLayout
        android:id="@+id/controls_layout"
        android:layout_width="387dp"
        android:layout_height="72dp"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/toggle_microphone_button"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"
            android:contentDescription="Mute"
            android:src="@drawable/ic_mic_on" />

        <ImageButton
            android:id="@+id/toggle_camera_button"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"
            android:contentDescription="Camera Toggle"
            android:src="@drawable/ic_video_on" />

        <ImageButton
            android:id="@+id/end_call_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background_red"
            android:contentDescription="End Call"
            android:src="@drawable/ic_end_call" />

        <ImageButton
            android:id="@+id/switch_camera_button"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"
            android:contentDescription="Switch Camera"
            android:src="@drawable/ic_switch_camera" />

        <ImageButton
            android:id="@+id/toggle_audio_device"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_background"
            android:contentDescription="Audio Output"
            android:src="@drawable/ic_speaker" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
