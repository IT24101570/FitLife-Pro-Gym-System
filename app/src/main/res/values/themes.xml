<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Fit_lifeGym" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryDark">@color/bg_luxury</item>
        <item name="colorAccent">@color/gold_primary</item>
        
        <!-- Background colors -->
        <item name="android:windowBackground">@color/bg_luxury</item>
        <item name="android:colorBackground">@color/bg_luxury</item>
        <item name="android:navigationBarColor">@color/bg_luxury</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_off_white</item>
        <item name="android:textColorSecondary">@color/text_muted_gold</item>
        <item name="android:textColorHint">@color/text_muted_gold</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_luxury</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Material Components default styling -->
        <item name="materialCardViewStyle">@style/PremiumCard</item>
        <item name="materialButtonStyle">@style/PremiumButton</item>
    </style>

    <style name="Theme.Fit_lifeGym" parent="Base.Theme.Fit_lifeGym" />

    <!-- Premium Card Style -->
    <style name="PremiumCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_luxury</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <!-- Premium Button Style -->
    <style name="PremiumButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/gold_primary</item>
        <item name="android:textColor">@color/bg_luxury</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingVertical">18dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="PremiumButtonSmall" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/gold_primary</item>
        <item name="android:textColor">@color/bg_luxury</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
