<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Fit_lifeGym" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        
        <!-- Background colors -->
        
        <!-- Text colors -->

        <!-- Status bar -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Material Components default styling -->
        <item name="materialCardViewStyle">@style/PremiumCard</item>
        <item name="materialButtonStyle">@style/PremiumButton</item>
    </style>

    <style name="Theme.Fit_lifeGym" parent="Base.Theme.Fit_lifeGym" />

    <!-- Premium Card Style -->
    <style name="PremiumCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <!-- Premium Button Style -->
    <style name="PremiumButton" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
